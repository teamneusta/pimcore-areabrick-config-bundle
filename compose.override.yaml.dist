services:
  php:
    environment:
      COMPOSER_HOME:
      COMPOSER_CACHE_DIR:
      PIMCORE_ENCRYPTION_SECRET: 'replace_with_secret'
      PIMCORE_INSTANCE_IDENTIFIER: 'replace_with_secret'
      PIMCORE_PRODUCT_KEY: 'replace_with_secret'
    volumes:
      - ${COMPOSER_HOME:-$HOME/.config/composer}:$COMPOSER_HOME
      - ${COMPOSER_CACHE_DIR:-$HOME/.cache/composer}:$COMPOSER_CACHE_DIR
